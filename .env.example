# rpow2 banker — the wallet that receives bets and pays out winners
BANKER_EMAIL=banker@yourdomain.com

# rpow2 API
RPOW_API_BASE=https://api.rpow2.com
# Pick one auth method (cookie OR token). Cookie is what rpow2 currently uses.
RPOW_SESSION_COOKIE=
RPOW_API_TOKEN=

# market params
RAKE_BPS=0
ROUND_SECONDS=300
ACCEPT_SECONDS=240
MIN_BET_BASE=1
MAX_BET_RPOW=1000
MAX_CLOCK_SKEW_MS=300000

# storage
DB_PATH=./data/market.db
