# ─── token: rPOW2 ────────────────────────────────────────
RPOW2_BANKER=banker@yourdomain.com
RPOW2_COOKIE=
# RPOW2_TOKEN=
# RPOW2_API_BASE=https://api.rpow2.com    # default

# ─── token: rPOW3 ────────────────────────────────────────
# RPOW3_BANKER=banker@yourdomain.com
# RPOW3_COOKIE=
# RPOW3_API_BASE=https://api.rpow3.com    # default

# ─── token: rPOW4 ────────────────────────────────────────
# RPOW4_BANKER=<base58-pubkey>     # rpow4 uses pubkeys, not emails
# RPOW4_COOKIE=
# RPOW4_API_BASE=https://api.rpow4.com    # default
# RPOW4_SEED="word1 word2 ... word12"    # 12-word BIP39 mnemonic; required to sign rpow4 sends

# ─── market params ───────────────────────────────────────
RAKE_BPS=0
ROUND_SECONDS=300
ACCEPT_SECONDS=240
MIN_BET_BASE=1
MAX_BET_RPOW=21000000
MAX_CLOCK_SKEW_MS=300000
DB_PATH=./data/market.db

# ─── legacy (still works for rpow2 backward compat) ──────
# BANKER_EMAIL=
# RPOW_SESSION_COOKIE=
# RPOW_API_TOKEN=
# RPOW_API_BASE=
